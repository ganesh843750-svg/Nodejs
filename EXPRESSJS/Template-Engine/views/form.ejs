<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Info</title>
</head>
<body>
    <form action="submit" method="POST">
        <input type="text" placeholder="Enter your name" name="name"><br><br>
        <input type="email" placeholder="Enter your Email" name="email"><br><br>
        <input type="number" placeholder="Enter your Age" name="age"><br><br>
        <input type="number" placeholder="Enter your Mobile No " name="phone"><br><br>
        <input type="text" placeholder="Enter your Country" name="country"><br><br>
        <input type="text" placeholder="Enter your State" name="state"><br><br>
        <button>Submit</button>
    </form>
    
</body>
</html>